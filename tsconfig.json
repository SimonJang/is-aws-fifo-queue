{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"declaration": true,
		"removeComments": true,
		"pretty": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"strict": true,
		"outDir": "lib"
	},
	"exclude": [
		"node_modules",
		"source/test",
		"lib"
	]
}
